# Copy this file to `.env` (which is gitignored) and fill in whatever you use.
# Every var is optional — the env works without any keys; LLM-backed policies
# require whichever provider you want to hit.
#
# Usage:
#   cp .env.example .env
#   # edit .env, then:
#   set -a; source .env; set +a            # bash
#   Get-Content .env | ForEach-Object ...  # PowerShell (see README)

# -------- LLM providers (pick any, all optional) -------------------------- #

# NVIDIA Build catalog (https://build.nvidia.com) — OpenAI-compatible.
# Free tier has tight RPM; paid/cloud creds are far better.
NVIDIA_API_KEY=

# Groq (https://console.groq.com/keys) — OpenAI-compatible, fastest inference.
# Free tier has a 6K TPM cap on 70B class; 8B class is much looser (500K TPM).
GROQ_API_KEY=

# OpenRouter (https://openrouter.ai/keys) — meta-aggregator.
# Many :free models but 3rd-party providers rate-limit aggressively.
OPENROUTER_API_KEY=

# OpenAI direct — full GPT-4 / GPT-4o / etc.
OPENAI_API_KEY=

# Anthropic direct — full Claude lineup.
ANTHROPIC_API_KEY=

# HuggingFace Hub — needed to download gated models (Llama, Gemma, Mistral).
# Get one at https://huggingface.co/settings/tokens (create, then grant read).
HF_TOKEN=
# Some libraries look for HUGGING_FACE_HUB_TOKEN instead; mirror the same value.
HUGGING_FACE_HUB_TOKEN=

# -------- Critic and stakeholder-persona LLM backends --------------------- #

# The step-level critic (Silicon-Mirror-style) can call out to an LLM.
# Defaults to a rule-based critic when no key is set.
CRITIC_PROVIDER=openai         # openai | anthropic
CRITIC_MODEL=gpt-4o-mini       # pick a cheap fast model

# LLM-backed stakeholder persona driver (used at L2+).
# Rule-based scripted stakeholders work without this.
STAKEHOLDER_LLM_PROVIDER=openai
STAKEHOLDER_LLM_MODEL=gpt-4o-mini

# -------- Runtime knobs --------------------------------------------------- #

# Uvicorn port for the FastAPI server.
PORT=7860

# Max retry attempts for LLM policies when rate-limited.
# Defaults to 8 if unset.
LLM_MAX_ATTEMPTS=8

# Repo URL used by Colab notebooks to clone the code.
STAKEHOLDER_GYM_REPO=https://github.com/SAISriram19/meta.git
